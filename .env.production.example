# ── Production Environment ──
# Copy this to .env.production and fill in your live values

# Database
DATABASE_URL=postgresql://postgres:postgres123@db:5432/ai_career_copilot

# Groq API Keys (RR pool)
GROQ_API_KEY_1=
GROQ_API_KEY_2=

# Groq API Keys (JD pool)
GROQ_API_KEY_3=
GROQ_API_KEY_4=

# Shared emergency key
GROQ_API_KEY_5=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Razorpay (LIVE keys — get from Razorpay dashboard after domain verification)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email (for OTP)
EMAIL_USER=
EMAIL_PASSWORD=

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Backend URL (for webhooks)
BACKEND_URL=https://your-backend-domain.railway.app
